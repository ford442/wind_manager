{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // Full strict mode: catches null/undefined, implicit any, unsafe casts, and
    // loose function types across the WebGPU sim + UI. Prefer typed helpers over
    // @ts-expect-error; use the latter only when @webgpu/types lags the runtime API.
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["@webgpu/types"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts", "vite.config.js"],
  "exclude": ["node_modules", "dist"]
}
